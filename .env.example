# ==============================================================================
# 1. CORE BACKEND SYSTEM RUNTIME CONFIGURATIONS
# ==============================================================================
PORT=5000
NODE_ENV=development

# Absolute root URL pointing to the running backend service framework
BACKEND_URL=http://localhost:5000

# Security cryptographic hash keys used for JWT token signing operations
JWT_SECRET=your_jwt_signing_secret_key_here
JWT_EXPIRES_IN=7d

# ==============================================================================
# 2. DISTRIBUTED CLOUD DATABASE INFRASTRUCTURE (MONGODB)
# ==============================================================================
# Connection URI string used to securely bind the application layer to Mongo data rooms
MONGO_URI=mongodb://localhost:27017/mirror_me_db

# ==============================================================================
# 3. AMAZON WEB SERVICES (AWS) S3 MEDIA STORAGE VAULT
# ==============================================================================
# Cryptographic access keys authorized to read/write binary media files to S3 buckets
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1

# Target cloud object storage bucket allocations for videos and voice audio tracks
AWS_S3_BUCKET_NAME=mirror-me-media-vault

# ==============================================================================
# 4. EXTERNAL ARTIFICIAL INTELLIGENCE PIPELINE INTEGRATIONS
# ==============================================================================
# OpenAI API platform credential keys utilized for transcription and sentiment processing
OPENAI_API_KEY=sk-proj-yourOpenAiPlatformSecretKeyGoesHere

# ElevenLabs speech synthesis authorization tokens used to run custom voice prints
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# HeyGen video translation platform token arrays for handling avatar generation
HEYGEN_API_KEY=your_heygen_api_key_here

# ==============================================================================
# 5. FRONTEND APPLICATION ENVIRONMENT LAYERS (NEXT.JS)
# ==============================================================================
# Target destination address for Next.js cross-origin request routing structures
NEXT_PUBLIC_API_URL=http://localhost:5000
