# ============================================================================
# MIRROR ME BACKEND CORE NODE.JS ENVIRONMENT CONFIGURATION BLUEPRINT
# Copy this file to '.env' and populate it with your local/production credentials.
# ============================================================================

# ----------------------------------------------------------------------------
# 1. APPLICATION LIFECYCLE SETTINGS
# ----------------------------------------------------------------------------
# Options: development, production, test
NODE_ENV=development
PORT=5000

# Comma-separated list of allowed web frontend domains (Next.js client workspace)
ALLOWED_ORIGINS=http://localhost:3000,https://mirror-me.com


# ----------------------------------------------------------------------------
# 2. CRYPTOGRAPHIC & SESSIONS SECURITY KEYS
# ----------------------------------------------------------------------------
# Generate a strong token string using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_ultra_secure_super_long_jwt_secret_key_here
JWT_EXPIRES_IN=7d


# ----------------------------------------------------------------------------
# 3. DUAL-DATABASE ARCHITECTURE POOL ENGINES
# ----------------------------------------------------------------------------
# Primary Relational DB (PostgreSQL) - Handles users, metadata schedules, and transactional billing
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_local_postgres_password_here
PG_DATABASE=mirror_me_relational

# Primary Document DB (MongoDB) - Handles rich AI metadata transcripts, logs, and state objects
# Example format: mongodb://username:password@localhost:27017/mirror_me_docs
MONGO_URI=mongodb://localhost:27017/mirror_me_documents


# ----------------------------------------------------------------------------
# 4. THIRD-PARTY API INFRASTRUCTURE CHANNELS
# ----------------------------------------------------------------------------
# Stripe Gateway - Payment orchestration and subscription webhooks sync
# Use 'sk_test_' strings for staging simulations
STRIPE_SECRET_KEY=sk_test_replace_with_your_actual_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_actual_stripe_webhook_signing_secret

# SendGrid Service - Asynchronous transactional outbound user notification emails
SENDGRID_API_KEY=SG.replace_with_your_actual_sendgrid_api_key_token
FROM_EMAIL=noreply@mirror-me.com

# Amazon Web Services S3 - High-volume media pipeline asset bucket hosting
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET_NAME=mirror-me-media-vault


# ----------------------------------------------------------------------------
# 5. INTERNAL AI PIPELINE INTER-SERVICE CONNECTIONS
# ----------------------------------------------------------------------------
# Gateway URL pointing to your Python FastAPI container running the machine learning/rendering pipeline
PYTHON_PIPELINE_URL=http://localhost:8000
